<script type="text/javascript">
require(['jquery'], function ($) {
    'use strict';

    var wizard = {
        currentStep: 1,
        totalSteps: 4,
        saveUrl: '<?= $block->escapeJs($saveUrl) ?>',
        selectedPreset: null,
        connectionTested: false,

        init: function () {
            this.bindEvents();
            <?php if ($completed && $configured): ?>
            // Already configured — show completion
            this.goToStep(5);
            <?php endif; ?>
        },

        bindEvents: function () {
            var self = this;

            // Test connection
            $('#btn-test').on('click', function () { self.testConnection(); });

            // Navigation
            $('#btn-next-1').on('click', function () { self.saveAndNext(1); });
            $('#btn-next-2').on('click', function () { self.saveAndNext(2); });
            $('#btn-next-3').on('click', function () { self.saveAndNext(3); });
            $('#btn-back-2').on('click', function () { self.goToStep(1); });
            $('#btn-back-3').on('click', function () { self.goToStep(2); });
            $('#btn-back-4').on('click', function () { self.goToStep(3); });
            $('#btn-activate').on('click', function () { self.activate(); });

            // Presets
            $('.te-wizard__preset').on('click', function () {
                self.selectPreset($(this).data('preset'));
            });

            // Warmup parent toggle
            $('#feat-warmup').on('change', function () {
                var on = $(this).is(':checked');
                $('#warmup-homepage-row, #warmup-cats-row, #warmup-sitemap-row')
                    .css('opacity', on ? 1 : 0.4)
                    .find('input').prop('disabled', !on);
            });

            // Enable Next after typing credentials
            $('#te-company-id, #te-client-id, #te-client-secret').on('input', function () {
                self.connectionTested = false;
                $('#btn-next-1').prop('disabled', true);
                $('#te-test-status').hide().removeClass('success error');
            });
        },

        testConnection: function () {
            var self = this;
            var $btn = $('#btn-test');
            var $status = $('#te-test-status');

            var companyId    = $('#te-company-id').val().trim();
            var clientId     = $('#te-client-id').val().trim();
            var clientSecret = $('#te-client-secret').val().trim();

            if (!companyId || !clientId || !clientSecret) {
                $status.removeClass('success info').addClass('error')
                    .text('<?= $block->escapeJs(__('Please fill in all three fields.')) ?>').show();
                return;
            }

            $btn.prop('disabled', true).html('<span class="te-spinner"></span> <?= $block->escapeJs(__('Testing...')) ?>');
            $status.hide();

            $.ajax({
                url: self.saveUrl,
                type: 'POST',
                dataType: 'json',
                data: {
                    form_key: FORM_KEY,
                    wizard_action: 'test_connection',
                    company_id: companyId,
                    client_id: clientId,
                    client_secret: clientSecret
                },
                success: function (res) {
                    $btn.prop('disabled', false).text('<?= $block->escapeJs(__('Test Connection')) ?>');
                    if (res.success) {
                        $status.removeClass('error info').addClass('success')
                            .html('✓ ' + res.message).show();
                        self.connectionTested = true;
                        $('#btn-next-1').prop('disabled', false);
                    } else {
                        $status.removeClass('success info').addClass('error')
                            .html('✗ ' + res.message).show();
                        self.connectionTested = false;
                        $('#btn-next-1').prop('disabled', true);
                    }
                },
                error: function () {
                    $btn.prop('disabled', false).text('<?= $block->escapeJs(__('Test Connection')) ?>');
                    $status.removeClass('success info').addClass('error')
                        .text('<?= $block->escapeJs(__('Network error. Please try again.')) ?>').show();
                }
            });
        },

        selectPreset: function (preset) {
            this.selectedPreset = preset;
            $('.te-wizard__preset').removeClass('selected');
            $('#preset-' + preset).addClass('selected');
            $('#btn-next-2').prop('disabled', false);

            var details = {
                ecommerce: '<?= $block->escapeJs(__('HTML: s-maxage=14400 (4h), max-age=600 (10min) · Static: s-maxage=2592000 (30d) · Soft Purge: ON')) ?>',
                standard: '<?= $block->escapeJs(__('HTML: s-maxage=86400 (24h), max-age=1800 (30min) · Static: s-maxage=2592000 (30d) · Soft Purge: ON')) ?>',
                aggressive: '<?= $block->escapeJs(__('HTML: s-maxage=172800 (48h), max-age=3600 (1h) · Static: s-maxage=2592000 (30d) · Soft Purge: ON')) ?>'
            };
            $('#te-preset-detail').html(details[preset]).show();
        },

        saveAndNext: function (step) {
            var self = this;
            var data = { form_key: FORM_KEY };

            switch (step) {
                case 1:
                    data.wizard_action = 'save_credentials';
                    data.company_id    = $('#te-company-id').val().trim();
                    data.client_id     = $('#te-client-id').val().trim();
                    data.client_secret = $('#te-client-secret').val().trim();
                    break;

                case 2:
                    data.wizard_action = 'save_cache';
                    data.preset = self.selectedPreset;
                    break;

                case 3:
                    data.wizard_action = 'save_features';
                    data.warmup_enabled    = $('#feat-warmup').is(':checked') ? '1' : '0';
                    data.warmup_homepage   = $('#feat-warmup-homepage').is(':checked') ? '1' : '0';
                    data.warmup_categories = $('#feat-warmup-categories').is(':checked') ? '1' : '0';
                    data.warmup_sitemap    = $('#feat-warmup-sitemap').is(':checked') ? '1' : '0';
                    data.warmup_rate_limit = '3';
                    data.i3_enabled        = $('#feat-i3').is(':checked') ? '1' : '0';
                    data.i3_auto_webp      = '1';
                    data.i3_quality        = '85';
                    data.admin_bypass      = $('#feat-admin-bypass').is(':checked') ? '1' : '0';
                    break;
            }

            $.ajax({
                url: self.saveUrl,
                type: 'POST',
                dataType: 'json',
                data: data,
                success: function () {
                    if (step === 3) {
                        self.buildSummary();
                    }
                    self.goToStep(step + 1);
                },
                error: function () {
                    alert('<?= $block->escapeJs(__('Error saving configuration. Please try again.')) ?>');
                }
            });
        },

        activate: function () {
            var self = this;
            var $btn = $('#btn-activate');
            var $status = $('#te-activate-status');

            $btn.prop('disabled', true).html('<span class="te-spinner"></span> <?= $block->escapeJs(__('Activating...')) ?>');

            $.ajax({
                url: self.saveUrl,
                type: 'POST',
                dataType: 'json',
                data: {
                    form_key: FORM_KEY,
                    wizard_action: 'activate'
                },
                success: function (res) {
                    if (res.success) {
                        self.goToStep(5);
                    } else {
                        $btn.prop('disabled', false).html('✓ <?= $block->escapeJs(__('Activate CDN')) ?>');
                        $status.removeClass('success info').addClass('error')
                            .text('✗ ' + res.message).show();
                    }
                },
                error: function () {
                    $btn.prop('disabled', false).html('✓ <?= $block->escapeJs(__('Activate CDN')) ?>');
                    $status.removeClass('success info').addClass('error')
                        .text('<?= $block->escapeJs(__('Network error. Please try again.')) ?>').show();
                }
            });
        },

        buildSummary: function () {
            var presetNames = {
                ecommerce: '<?= $block->escapeJs(__('Ecommerce')) ?>',
                standard: '<?= $block->escapeJs(__('Standard')) ?>',
                aggressive: '<?= $block->escapeJs(__('Aggressive')) ?>'
            };
            var presetTtls = {
                ecommerce: '4h CDN / 10min browser',
                standard: '24h CDN / 30min browser',
                aggressive: '48h CDN / 1h browser'
            };

            var rows = [
                ['<?= $block->escapeJs(__('Company ID')) ?>', $('#te-company-id').val()],
                ['<?= $block->escapeJs(__('API Connection')) ?>', '<span style="color:#0a6e3f;">✓ <?= $block->escapeJs(__('Verified')) ?></span>'],
                ['<?= $block->escapeJs(__('Cache Preset')) ?>', presetNames[this.selectedPreset] || '-'],
                ['<?= $block->escapeJs(__('HTML TTLs')) ?>', presetTtls[this.selectedPreset] || '-'],
                ['<?= $block->escapeJs(__('Static TTLs')) ?>', '30d CDN / 1d browser'],
                ['<?= $block->escapeJs(__('Soft Purge')) ?>', '<?= $block->escapeJs(__('Enabled')) ?>'],
                ['<?= $block->escapeJs(__('Cache Warm-up')) ?>', $('#feat-warmup').is(':checked') ? '✓' : '✗'],
                ['<?= $block->escapeJs(__('i3 Images')) ?>', $('#feat-i3').is(':checked') ? '✓ (<?= $block->escapeJs(__('requires VCL setup')) ?>)' : '✗'],
                ['<?= $block->escapeJs(__('Admin Bypass')) ?>', $('#feat-admin-bypass').is(':checked') ? '✓' : '✗'],
            ];

            var html = '';
            rows.forEach(function (row) {
                html += '<tr><td>' + row[0] + '</td><td>' + row[1] + '</td></tr>';
            });
            $('#te-summary').html(html);
        },

        goToStep: function (step) {
            this.currentStep = step;

            // Update cards
            $('.te-wizard__card').removeClass('active');
            $('#step-' + step).addClass('active');

            // Update progress dots and lines
            for (var i = 1; i <= this.totalSteps; i++) {
                var $dot   = $('[data-step="' + i + '"]');
                var $label = $dot.next('.te-wizard__step-label');
                var $line  = $('[data-line="' + i + '"]');

                $dot.removeClass('active completed');
                $label.removeClass('active');

                if (i < step) {
                    $dot.addClass('completed').html('✓');
                    if ($line.length) $line.addClass('completed');
                } else if (i === step && step <= this.totalSteps) {
                    $dot.addClass('active').text(i);
                    $label.addClass('active');
                } else {
                    $dot.text(i);
                    if ($line.length) $line.removeClass('completed');
                }
            }

            // Hide progress on completion step
            if (step === 5) {
                $('#te-progress').hide();
            }

            // Scroll to top
            $('html, body').animate({ scrollTop: $('#te-wizard').offset().top - 20 }, 200);
        }
    };

    wizard.init();
});
</script>
