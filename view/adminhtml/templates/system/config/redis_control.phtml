<script type="text/javascript">
require(['jquery'], function ($) {
    'use strict';

    var manageUrl = '<?= $block->escapeJs($manageUrl) ?>';
    var detectedHost = '';
    var detectedPort = 6379;
    var detectedPassword = '';
    var recommendedDbs = {cache: 0, fpc: 2, session: 3};

    // Translated strings for JS
    var i18n = {
        detect: '<?= $block->escapeJs(__('Detect')) ?>',
        detecting: '<?= $block->escapeJs(__('Detecting...')) ?>',
        enable: '<?= $block->escapeJs(__('Enable')) ?>',
        disable: '<?= $block->escapeJs(__('Disable')) ?>',
        files: '<?= $block->escapeJs(__('Files')) ?>',
        networkError: '<?= $block->escapeJs(__('Network error.')) ?>',
        notFound: '<?= $block->escapeJs(__('Redis not found.')) ?>',
        detectFirst: '<?= $block->escapeJs(__('Click Detect first to find Redis.')) ?>',
        confirmDisable: '<?= $block->escapeJs(__('Disable Redis for this backend? It will revert to file-based storage.')) ?>',
        confirmRollback: '<?= $block->escapeJs(__('Restore env.php from backup? This will undo the last Redis change.')) ?>'
    };

    function ajaxCall(data, callback) {
        data.form_key = FORM_KEY;
        $.ajax({
            url: manageUrl,
            type: 'POST',
            dataType: 'json',
            data: data,
            success: callback,
            error: function () {
                showResult(i18n.networkError, false);
            }
        });
    }

    function showResult(msg, success) {
        var $r = $('#te-redis-detect-result');
        $r.html((success ? '<span style="color:#0a6e3f;">✓ </span>' : '<span style="color:#991b1b;">✗ </span>') + msg).show();
    }

    function updateUI(status) {
        if (!status) return;
        var types = ['cache', 'fpc', 'session'];
        types.forEach(function (t) {
            var on = status[t];
            var $badge = $('#te-redis-' + t + '-badge');
            var $btn = $('.te-redis-toggle[data-type="' + t + '"]');
            var $info = $('#te-redis-' + t + '-info');

            $badge.text(on ? 'Redis' : i18n.files)
                  .attr('style', 'font-size:11px;padding:2px 8px;border-radius:10px;' +
                      (on ? 'background:#edfdf5;color:#0a6e3f;' : 'background:#f3f4f6;color:#6b7280;'));

            $btn.text(on ? i18n.disable : i18n.enable)
                .attr('style', 'padding:6px 14px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;' +
                    (on ? 'background:#fee2e2;color:#991b1b;border:1px solid #fecaca;' : 'background:#002643;color:#fff;border:1px solid #002643;'));

            if (status.details && status.details[t]) {
                $info.text(status.details[t]);
            }
        });
    }

    // Detect
    $('#te-redis-detect').on('click', function () {
        var $btn = $(this);
        $btn.prop('disabled', true).text(i18n.detecting);

        ajaxCall({
            redis_action: 'detect',
            host: $('#te-redis-host').val(),
            port: $('#te-redis-port').val(),
            password: $('#te-redis-password').val()
        }, function (res) {
            $btn.prop('disabled', false).text(i18n.detect);
            if (res.available) {
                detectedHost = res.host;
                detectedPort = res.port;
                detectedPassword = $('#te-redis-password').val();
                if (res.recommended_dbs) recommendedDbs = res.recommended_dbs;
                showResult(res.message, true);
                if (res.status) updateUI(res.status);
            } else {
                showResult(res.message || i18n.notFound, false);
            }
        });
    });

    // Toggle enable/disable
    $('.te-redis-toggle').on('click', function () {
        var $btn = $(this);
        var type = $btn.data('type');
        var isEnabled = $btn.text().trim() === i18n.disable;

        if (isEnabled) {
            if (!confirm(i18n.confirmDisable)) return;
            $btn.prop('disabled', true).text('...');
            ajaxCall({redis_action: 'disable', type: type}, function (res) {
                $btn.prop('disabled', false);
                showResult(res.message, res.success);
                if (res.status) updateUI(res.status);
            });
        } else {
            if (!detectedHost) {
                showResult(i18n.detectFirst, false);
                return;
            }
            $btn.prop('disabled', true).text('...');
            ajaxCall({
                redis_action: 'enable',
                type: type,
                host: detectedHost,
                port: detectedPort,
                password: detectedPassword,
                database: recommendedDbs[type] || 0
            }, function (res) {
                $btn.prop('disabled', false);
                showResult(res.message, res.success);
                if (res.status) updateUI(res.status);
            });
        }
    });

    // Rollback
    $('#te-redis-rollback').on('click', function () {
        if (!confirm(i18n.confirmRollback)) return;
        ajaxCall({redis_action: 'rollback'}, function (res) {
            showResult(res.message, res.success);
            if (res.status) updateUI(res.status);
        });
    });
});
</script>
