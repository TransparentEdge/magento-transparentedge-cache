<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <transparentedge>
            <general>
                <enabled>0</enabled>
                <company_id/>
                <client_id/>
                <client_secret/>
                <wizard_completed>0</wizard_completed>
            </general>
            <cache>
                <html_ttl>172800</html_ttl>           <!-- 48h -->
                <html_browser_ttl>3600</html_browser_ttl>  <!-- 1h -->
                <static_ttl>2592000</static_ttl>       <!-- 30d -->
                <static_browser_ttl>86400</static_browser_ttl> <!-- 1d -->
                <stale_while_revalidate>86400</stale_while_revalidate> <!-- 1d -->
                <stale_if_error>86400</stale_if_error> <!-- 1d -->
                <soft_purge>1</soft_purge>
                <refetch>0</refetch>
            </cache>
            <warmup>
                <enabled>1</enabled>
                <homepage>1</homepage>
                <categories>1</categories>
                <sitemap>0</sitemap>
                <sitemap_url/>
                <rate_limit>3</rate_limit>
                <custom_urls/>
            </warmup>
            <i3>
                <enabled>0</enabled>
                <auto_webp>1</auto_webp>
                <quality>85</quality>
                <max_width>2560</max_width>
            </i3>
            <advanced>
                <admin_bypass>1</admin_bypass>
                <debug>0</debug>
                <exclude_urls/>
                <exclude_cookies/>
            </advanced>
            <wpo>
                <enabled>1</enabled>
                <preload>1</preload>
                <lazyload>1</lazyload>
                <dns_prefetch>1</dns_prefetch>
            </wpo>
        </transparentedge>
    </default>
</config>
